      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "from sklearn.linear_model import LinearRegression\n",
        "\n",
        "df = pd.read_csv('supermarket_sample.csv')\n",
        "\n",
        "# Feature engineering\n",
        "df['Traffic_x_Items']  = df['Foot_Traffic'] * df['High_Value_Items']\n",
        "df['Evening_Flag']     = (df['Hour'] > 17).astype(int)\n",
        "df['Staff_per_Traffic']= df['Staff_Count'] / df['Foot_Traffic']\n",
        "\n",
        "X = df[['Foot_Traffic', 'Staff_Count', 'Hour', 'High_Value_Items',\n",
        "        'Traffic_x_Items', 'Evening_Flag', 'Staff_per_Traffic']]\n",
        "y = df['Shrinkage_INR']\n",
        "\n",
        "model = LinearRegression()\n",
        "model.fit(X, y)\n",
        "\n",
        "print(\"Coefficients:\", model.coef_)\n",
        "print(\"Intercept (b):\", model.intercept_)\n",
        "\n",
        "prediction = model.predict([[300, 5, 14, 50, 300*50, 0, 5/300]])\n",
        "print(\"Predicted shrinkage: ₹\", round(prediction[0], 2))\n",
        "\n",
        "print(\"R² score:\", model.score(X, y))"
